{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaseos.local/schemas/runtime_surface_manifest.schema.json",
  "title": "ChaseOS Adaptive Runtime Surface Layer Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "surface_id",
    "display_name",
    "surface_family",
    "surface_type",
    "owner_layer",
    "status",
    "implementation_refs",
    "docs_refs",
    "trust_ceiling",
    "permission_model_refs",
    "gate_operations",
    "capabilities",
    "credential_policy",
    "fallback_policy",
    "writeback_surfaces",
    "audit_targets",
    "routing_policy",
    "mcp_exposure_policy"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "surface_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "surface_family": {
      "enum": [
        "provider_model_runtime",
        "agent_runtime",
        "browser_operator",
        "siteops_skill_runtime",
        "runtime_mcp",
        "client_embedded_runtime",
        "filesystem_surface",
        "terminal_surface",
        "desktop_surface"
      ]
    },
    "surface_type": {
      "enum": [
        "provider_model",
        "agent",
        "browser",
        "siteops_skill",
        "mcp",
        "client_embedded",
        "filesystem",
        "terminal",
        "desktop"
      ]
    },
    "owner_layer": { "type": "string", "minLength": 1 },
    "status": {
      "enum": [
        "COMPLETE",
        "PARTIAL",
        "PLANNED",
        "NOT BUILT",
        "DOCS-ONLY",
        "VERIFIED",
        "CONFIGURED BUT UNVERIFIED",
        "BLOCKED",
        "DEFERRED"
      ]
    },
    "implementation_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "docs_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "trust_ceiling": { "enum": ["tier-1", "tier-2", "tier-3", "tier-4"] },
    "permission_model_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "gate_operations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["capability_id", "maps_to", "risk_class", "approval_required"],
        "properties": {
          "capability_id": { "type": "string", "minLength": 1 },
          "maps_to": { "type": "string", "minLength": 1 },
          "risk_class": {
            "enum": [
              "read_local_scoped",
              "read_untrusted_external",
              "draft_only",
              "proposal_write",
              "quarantine_write",
              "canonical_write",
              "external_ui_read",
              "external_ui_mutation",
              "external_network_call",
              "credential_sensitive",
              "browser_profile_sensitive",
              "provider_fallback",
              "runtime_config_change",
              "security_policy_change",
              "destructive_action",
              "blocked"
            ]
          },
          "approval_required": {
            "oneOf": [
              { "type": "boolean" },
              { "const": "conditional" }
            ]
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "credential_policy": {
      "type": "object",
      "required": ["credentials_allowed", "cookies_allowed", "real_profile_allowed"],
      "properties": {
        "credentials_allowed": { "const": false },
        "cookies_allowed": { "const": false },
        "real_profile_allowed": { "const": false }
      },
      "additionalProperties": true
    },
    "fallback_policy": {
      "type": "object",
      "required": ["sticky_fallback_allowed"],
      "properties": {
        "sticky_fallback_allowed": { "const": false }
      },
      "additionalProperties": true
    },
    "writeback_surfaces": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "audit_targets": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "routing_policy": {
      "type": "object",
      "required": ["default", "authority_layer"],
      "properties": {
        "default": { "const": "deny_unknown" },
        "authority_layer": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "mcp_exposure_policy": {
      "type": "object",
      "required": ["expose_summary", "expose_raw_manifest"],
      "properties": {
        "expose_summary": { "type": "boolean" },
        "expose_raw_manifest": { "const": false }
      },
      "additionalProperties": true
    }
  }
}
