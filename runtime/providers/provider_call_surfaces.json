    "provider_state_policy": {
      "emit_provider_state_ledger": "Surface directly emits provider-state ledger events.",
      "emit_provider_state_ledger_via_shared_adapter": "Surface routes model execution through the shared adapter, which emits provider-state ledger events.",
      "source_intelligence_telemetry": "Surface belongs to Source Intelligence generation, embedding, or retrieval telemetry, not runtime provider fallback governance.",
      "connector_health_telemetry": "Surface belongs to capture or acquisition connector health telemetry, not runtime provider fallback governance.",
      "delivery_health_telemetry": "Surface belongs to external delivery health telemetry, not runtime provider fallback governance.",
      "runtime_health_telemetry": "Surface belongs to runtime lifecycle or setup health probes, not provider fallback governance.",
      "dry_run_control_plane_audit": "Surface prepares governed dry-run payloads or call drafts only; no live provider call is made."
    },
    "status": [
      "VERIFIED",
      "IMPLEMENTED",
      "PARTIAL",
      "PLANNED",
      "NOT BUILT",
