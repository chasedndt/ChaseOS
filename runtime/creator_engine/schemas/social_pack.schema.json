{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaseos.local/schemas/creator_engine/social_pack.schema.json",
  "title": "Creator Engine Social Pack",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "artifact_type",
    "job_id",
    "pack_path",
    "created_at",
    "target_platforms",
    "posts",
    "approval_required",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "creator_engine.v1" },
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "social_pack" },
    "job_id": { "type": "string" },
    "pack_path": { "type": "string" },
    "created_at": { "type": "string" },
    "target_platforms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "posts": {
      "type": "array",
      "items": { "type": "object" }
    },
    "approval_required": { "type": "boolean" },
    "status": { "type": "string" }
  },
  "additionalProperties": true
}
