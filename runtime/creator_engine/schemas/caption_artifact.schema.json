{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaseos.local/schemas/creator_engine/caption_artifact.schema.json",
  "title": "Creator Engine Caption Artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "artifact_type",
    "job_id",
    "caption_path",
    "created_at",
    "format",
    "status",
    "line_count",
    "warnings"
  ],
  "properties": {
    "schema_version": { "const": "creator_engine.v1" },
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "caption_artifact" },
    "job_id": { "type": "string" },
    "caption_path": { "type": "string" },
    "created_at": { "type": "string" },
    "format": { "type": "string" },
    "status": { "type": "string" },
    "line_count": { "type": "integer", "minimum": 0 },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
