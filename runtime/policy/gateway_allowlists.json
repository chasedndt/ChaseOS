  "external_apis": {
    "siteops.browser_execute": {
      "description": "SiteOps governed browser workflow execution. Read-only page capture only. No credentials, no form submission, no file download. Outputs route to quarantine.",
      "schemes": ["http", "https"],
      "approval_gate": "operator",
      "audit_requirement": "siteops_run_audit",
      "credential_required": false
    },
    "browser.navigation": {
      "description": "Bounded browser navigation/read/screenshot work.",
      "schemes": [
        "http",
        "https"
      ],
      "registry": "runtime/browser_registry/allowed_origins.yaml"
    },
    "capture.rss": {
      "description": "RSS/Atom feed fetches through the capture quarantine path.",
      "schemes": [
        "http",
        "https"
      ]
    },
    "host.process": {
      "description": "Bounded local host process start/stop actions for runtime lifecycle supervisors."
    },
    "host.scheduler": {
      "description": "Bounded local host scheduler query/register/unregister actions for runtime lifecycle bootstrap."
    },
    "host.startup_folder": {
      "description": "Bounded local Windows Startup-folder launcher create/remove actions for declared runtime gateways.",
      "approval_gate": "operator",
      "audit_requirement": "startup_write_tag"
    },
    "capture.perplexity": {
      "description": "Perplexity capture connector; credentials must be references only.",
      "credential_reference_required": true
    },
    "capture.grok": {
      "description": "Grok/xAI capture connector; credentials must be references only.",
      "credential_reference_required": true
    },
    "provider.anthropic": {
      "description": "Anthropic provider API setup/validation; setup state stores references only.",
      "credential_reference_required": true
    },
    "provider.openai": {
      "description": "OpenAI provider API setup/validation; setup state stores references only.",
      "credential_reference_required": true
    },
    "provider.local_oss_endpoint": {
      "description": "Local model endpoint health/probe calls.",
      "schemes": [
        "http",
        "https"
      ]
    },
    "provider.n8n_endpoint": {
      "description": "n8n endpoint health/probe calls.",
      "schemes": [
        "http",
        "https"
      ],
      "credential_reference_required": true
    },
    "delivery.discord_webhook": {
      "description": "Scheduled Briefing Pipeline delivery to Discord webhook endpoints. Webhook values must come from runtime environment references, not vault state.",
      "schemes": [
        "https"
      ],
      "credential_reference_required": true
    },
    "delivery.whop_api": {
      "description": "Scheduled Briefing Pipeline delivery to Whop API post endpoints. API keys must come from runtime environment references, not vault state.",
      "schemes": [
        "https"
      ],
      "credential_reference_required": true
    }
  },
  "control_plane_transports": {
    "runtime/agent_bus/": {
      "description": "ChaseOS-owned structured coordination state.",
      "coordination_source_of_truth": true
    },
    "discord": {
      "description": "Operator ingress/control surface; coordination-sensitive work must translate to runtime/agent_bus/."
    }
  },
  "credential_references": {
    "allowed_kinds": [
      "env-var",
      "env-var-or-local-secret-ref",
      "keychain-ref",
      "template-placeholder"
    ],
    "allowed_target_patterns": [
      {
        "id": "env_var_name",
        "regex": "^[A-Z][A-Z0-9_]{2,}$"
      },
      {
        "id": "template_placeholder",
        "regex": "^(SET|TODO|PLACEHOLDER)_[A-Z0-9_]+$"
      },
      {
        "id": "angle_placeholder",
        "regex": "^<[^<>]*(ENV|KEYCHAIN|SECRET|TOKEN|CREDENTIAL)[^<>]*>$"
      },
      {
        "id": "keychain_uri",
        "regex": "^(keychain|windows-credential|1password|op|secret-manager)://[A-Za-z0-9._/@:+-]+$"
      }
    ],
    "reference_only_state_keys": [
      "credential_reference",
      "credential_reference_target",
      "keychain_reference",
      "secret_reference_target",
      "token_reference"
    ],
    "secret_value_key_fragments": [
      "api_key",
      "client_secret",
      "password",
      "private_key",
      "secret",
      "token",
      "webhook"
    ]
  }
}
