# --- Runtime code that is private/generated until explicitly curated ---
runtime/acquisition/
runtime/adapters/
runtime/lifecycle/run/
runtime/lifecycle/bootstrap/
runtime/osril/run/
runtime/events/
runtime/studio/approvals/
runtime/studio/shell/frontend/assets/cytoscape.min.js
runtime/scaffold/generated/

# --- Runtime test sandboxes and local state/output (not public Core source) ---
runtime/**/_tmp*/
runtime/**/tmp_*/
runtime/**/state/
runtime/**/native-state/
runtime/**/out/
runtime/**/run/
runtime/setup_state.json
runtime/source_intelligence/workspaces/
runtime/studio/shell/qa_graph*.json

# --- ChaseOS runtime state (local machine state, not code) ---
.chaseos/
# Includes machine-local Discord bindings such as dedup_registry.json,
# watch_folders.json, watch_processed.json, config.yaml.

# --- SQLite databases (agent bus, artifact store) ---
*.db
*.db-wal
*.db-shm
*.sqlite
runtime/agent_bus/*.db*
runtime/acquisition/artifact_store.db*

# --- Large runtime artifacts (generated, not source) ---
runtime/acquisition/packs/
07_LOGS/Operator-Screenshots/

# --- Hermes and OpenClaw local state ---
.hermes/
.openclaw/

# --- Claude Code local session state ---
.claude/settings.local.json
.claude/hooks/__pycache__/

# --- VS Code workspace settings (keep .vscode/extensions.json if desired) ---
.vscode/settings.json
.vscode/launch.json

# --- macOS / Windows artifacts ---
.DS_Store
Thumbs.db
