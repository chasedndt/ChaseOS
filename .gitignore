# ============================================================
# ChaseOS .gitignore
# ============================================================
# Tracks: vault markdown, runtime code, policy, manifests, templates.
# Never tracks: credentials, env files, local state, large artifacts,
#               Python cache, venv, Obsidian app config, SQLite dbs.
# ============================================================

# --- Credentials and secrets ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
secrets/
credentials/

# --- Python runtime ---
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg

# --- Test and temp artifacts ---
.pytest_cache/
.pytest-tmp/
.pytest_tmp/
.pytest_tmp_env/
.codex/
.codex-*/
.codex_tmp/
.codex_tmp_test/
.tmp/
*.tmp

# --- Obsidian app config (not content) ---
.obsidian/

# --- ChaseOS local export/build state (not public repo payload) ---
core_export/
core_templates/

# --- ChaseOS runtime state (local machine state, not code) ---
.chaseos/
# Includes machine-local Discord bindings such as

# .chaseos/ contains: dedup_registry.json, watch_folders.json,
# watch_processed.json, config.yaml — all local machine state,
# not portable or meaningful in version control.

# --- SQLite databases (agent bus, artifact store) ---
*.db
*.db-wal
*.db-shm
*.sqlite
runtime/agent_bus/*.db*
runtime/acquisition/artifact_store.db*

# --- Large runtime artifacts (generated, not source) ---
runtime/acquisition/packs/
runtime/scaffold/generated/
07_LOGS/Operator-Screenshots/

# --- Studio shell state ---
runtime/studio/approvals/
runtime/studio/shell/frontend/assets/cytoscape.min.js

# --- Runtime lifecycle and process state ---
runtime/lifecycle/run/
runtime/lifecycle/bootstrap/
runtime/osril/run/
runtime/events/

# --- Hermes and OpenClaw local state ---
.hermes/
.openclaw/

# --- Claude Code local session state (NOT the hooks/settings.json — those are tracked) ---
.claude/settings.local.json
.claude/hooks/__pycache__/

# --- VS Code workspace settings (keep .vscode/extensions.json if desired) ---
.vscode/settings.json
.vscode/launch.json

# --- macOS artifacts (if ever synced) ---
.DS_Store
Thumbs.db
