# ============================================================
# ChaseOS .gitignore
# ============================================================
# Tracks: public-safe Core framework docs, templates, runtime code,
# policy examples, manifests, and package metadata.
# Never tracks: credentials, env files, local/private vault content,
# machine runtime state, generated artifacts, caches, databases, or media.
# ============================================================

# --- Credentials and secrets ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
secrets/
credentials/

# --- Python runtime ---
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg

# --- Test and temp artifacts ---
.pytest_cache/
.pytest-tmp/
.pytest_tmp/
.pytest_tmp_env/
.codex/
.codex-*/
.codex_tmp/
.codex_tmp_test/
.tmp/
*.tmp

# --- Obsidian app config (not content) ---
.obsidian/

# --- ChaseOS local/private source-vault material not part of public Core payload ---
.audit_tmp/
.claude/
core_export/
core_templates/
CLAUDE.md
GOAL.md
HERMES.md
KNOWLEDGE-INDEX.md
N8N.md
OPENAI.md
OPENCLAW.md
OPERATOR-BRIEF-INDEX.md
SOUL.md
STRIKEZONE-DISCORD-SETUP.md
*.patch
ChaseOS Branding/
fixtures/
kernel/
