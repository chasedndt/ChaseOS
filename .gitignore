# ChaseOS Core production ignore rules

# Credentials and local config
.env
.env.*
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.asc
*.kdbx
*.secret
*.token
secrets/
credentials/
private/
local_config/
config.local.*

# Python and package artifacts
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.exe
*.msi
*.dmg
*.pkg
*.app/
*.zip
*.7z
*.tar
*.tar.gz
*.tgz
*.whl
*.egg-info/
*.egg
uv.lock

# Web artifacts
node_modules/
.next/
.nuxt/
out/
coverage/

# Tool, cache, and temp state
.*/
!.gitignore
.pytest_cache/
.pytest_tmp_env/
.uv-cache/
logs/
tmp/
temp/
.tmp/
*.tmp

# Databases and generated state
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.duckdb
*.jsonl

# Local notes, docs, exports, demos, and handoffs
/*.md
!README.md
*.patch
conftest.py
ChaseOS*/
00_HOME/
01_PROJECTS/
02_KNOWLEDGE/
03_INPUTS/
04_SOPS/
05_PROMPTS/
05_TEMPLATES/
06_AGENTS/
07_LOGS/
99_ARCHIVE/
website/
core_export/
core_templates/
docs/
fixtures/
kernel/
subagents/
security/

# Runtime: keep only the minimal production CLI package tracked
runtime/*
!runtime/cli/
runtime/cli/*
!runtime/cli/__init__.py
!runtime/cli/main.py

# Local OS/editor files
.vscode/settings.json
.vscode/launch.json
.DS_Store
Thumbs.db
